# CampusOS Backend — Environment Configuration
# Copy this file to .env and fill in your values

# =========================
# Application
# =========================
APP_NAME=CampusOS API
ENV=development
DEBUG=true

# =========================
# Security
# =========================
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkeyforcampusosmvpdevelopmentphase1

# =========================
# Database — MongoDB
# =========================
# Local development:
MONGODB_URL=mongodb://localhost:27017/campusos

# MongoDB Atlas (production):
# MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/campusos?retryWrites=true&w=majority

# =========================
# Cache — Redis
# =========================
# Falls back to in-memory if Redis is unavailable
REDIS_URL=redis://localhost:6379/0

# =========================
# File Storage — Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=campusos-dev
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
