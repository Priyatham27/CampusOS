{
  "name": "campusos-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=frontend",
    "web:build": "npm run build --workspace=frontend",
    "web:start": "npm run start --workspace=frontend",
    "api:dev": "python -m uvicorn backend.app.main:app --reload --port 8000"
  }
}
